<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AnthonyTablerAI — Never Miss Another Lead</title>
<meta name="description" content="AI receptionist for real estate agents. Find out what missed calls are costing you — then fix it in 7 days.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>

/* ═══ TOKENS ═══ */
:root {
  --black: #040403;
  --s1: #090908;
  --s2: #0E0E0D;
  --s3: #141413;
  --border: #1E1E1C;
  --border2: #2A2A27;
  --gold: #C8A84B;
  --gold-b: #E4BE66;
  --gold-c: #F5D78A;
  --gold-dim: rgba(200,168,75,.06);
  --gold-mid: rgba(200,168,75,.12);
  --gold-glow: rgba(200,168,75,.22);
  --text: #F6F6F0;
  --muted: #9A9A90;
  --dim: #4E4E49;
  --green: #7EC49A;
  --red: #D96B6B;
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body {
  background: var(--black);
  color: var(--text);
  font-family: 'Outfit', system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
a { text-decoration:none; color:inherit; }

/* ═══ CURSOR GLOW ═══ */
#cursor-glow {
  position: fixed;
  width: 500px; height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200,168,75,.055) 0%, transparent 65%);
  pointer-events: none;
  transform: translate(-50%,-50%);
  z-index: 0;
  transition: left .08s linear, top .08s linear;
  will-change: left, top;
}

/* ═══ NOISE ═══ */
#noise {
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 9998;
  opacity: .7;
}

/* ═══ NAV ═══ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 9000;
  height: 60px;
  padding: 0 max(20px, 4.5vw);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(4,4,3,.7);
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  border-bottom: 1px solid rgba(200,168,75,.08);
  transition: background .4s;
}
nav.scrolled { background: rgba(4,4,3,.92); }
.logo {
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  font-size: 14px;
  letter-spacing: .05em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 9px;
}
.logo-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--gold);
  box-shadow: 0 0 10px var(--gold-glow);
  animation: logo-pulse 2.4s ease-in-out infinite;
}
@keyframes logo-pulse {
  0%,100%{box-shadow:0 0 6px var(--gold-glow);}
  50%{box-shadow:0 0 18px var(--gold-glow),0 0 36px rgba(200,168,75,.08);}
}
.nav-right { display:flex; align-items:center; gap:16px; }
.nav-link {
  font-size: 13px;
  color: var(--muted);
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: .06em;
  text-transform: uppercase;
  transition: color .2s;
  display: none;
}
@media(min-width:600px){ .nav-link { display:block; } }
.nav-link:hover { color: var(--gold); }
.nav-btn {
  background: var(--gold);
  color: #040403;
  font-family: 'Outfit', sans-serif;
  font-weight: 600;
  font-size: 13px;
  letter-spacing: .04em;
  padding: 9px 22px;
  border-radius: 100px;
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  transition: all .22s;
  white-space: nowrap;
}
.nav-btn:hover { background:var(--gold-b); transform:translateY(-1px); box-shadow:0 6px 24px rgba(200,168,75,.25); }

/* ═══ HERO ═══ */
.hero {
  min-height: 100svh;
  padding: 120px max(20px,5vw) 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* Animated gradient orbs */
.orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(80px);
}
.orb-1 {
  width: 700px; height: 700px;
  top: -200px; right: -150px;
  background: radial-gradient(circle, rgba(200,168,75,.07) 0%, transparent 70%);
  animation: orb-drift 14s ease-in-out infinite alternate;
}
.orb-2 {
  width: 400px; height: 400px;
  bottom: -100px; left: -100px;
  background: radial-gradient(circle, rgba(200,168,75,.05) 0%, transparent 70%);
  animation: orb-drift 18s ease-in-out infinite alternate-reverse;
}
@keyframes orb-drift {
  0%{transform:translate(0,0) scale(1);}
  100%{transform:translate(30px,20px) scale(1.08);}
}

/* Grid lines */
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(200,168,75,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,168,75,.04) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 20%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 40%, black 20%, transparent 100%);
}

/* Ghost number */
.hero-ghost {
  position: absolute;
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(180px, 28vw, 340px);
  color: rgba(200,168,75,.03);
  top: 50%; left: 50%;
  transform: translate(-40%, -50%);
  pointer-events: none;
  white-space: nowrap;
  letter-spacing: -.02em;
  user-select: none;
}

.hero-inner {
  position: relative;
  max-width: 1100px;
  z-index: 2;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(200,168,75,.07);
  border: 1px solid rgba(200,168,75,.18);
  border-radius: 100px;
  padding: 6px 16px 6px 10px;
  margin-bottom: 36px;
}
.hero-eyebrow-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--gold);
  box-shadow: 0 0 8px var(--gold-glow);
}
.hero-eyebrow span {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--gold);
}

.hero-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(52px, 8.5vw, 112px);
  line-height: .95;
  letter-spacing: .01em;
  margin-bottom: 32px;
  overflow: hidden;
}
.hero-headline .line {
  display: block;
  overflow: hidden;
}
.hero-headline .line-inner {
  display: block;
  transform: translateY(110%);
  animation: line-up .9s cubic-bezier(.16,1,.3,1) forwards;
}
.hero-headline .line:nth-child(2) .line-inner { animation-delay: .12s; }
.hero-headline .line:nth-child(3) .line-inner { animation-delay: .24s; }
.hero-headline .gold { color: var(--gold); }

.hero-sub {
  font-size: clamp(16px, 1.7vw, 20px);
  color: var(--muted);
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: 44px;
  font-weight: 300;
  opacity: 0;
  animation: fade-up .8s ease .5s forwards;
}
.hero-sub strong { color: var(--text); font-weight: 500; }

@keyframes line-up {
  to { transform: translateY(0); }
}
@keyframes fade-up {
  from { opacity:0; transform:translateY(16px); }
  to   { opacity:1; transform:translateY(0); }
}

.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  opacity: 0;
  animation: fade-up .8s ease .7s forwards;
}

.btn-primary {
  background: var(--gold);
  color: #040403;
  font-weight: 600;
  font-size: 15px;
  padding: 16px 34px;
  border-radius: 100px;
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: all .22s;
  letter-spacing: .01em;
  font-family: 'Outfit', sans-serif;
}
.btn-primary:hover { background:var(--gold-b); transform:translateY(-2px); box-shadow:0 14px 48px rgba(200,168,75,.3); }

.btn-ghost {
  color: var(--text);
  font-weight: 500;
  font-size: 15px;
  padding: 16px 34px;
  border-radius: 100px;
  border: 1px solid var(--border2);
  background: transparent;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: all .22s;
  font-family: 'Outfit', sans-serif;
}
.btn-ghost:hover { border-color: rgba(200,168,75,.3); background: var(--gold-dim); color: var(--gold-b); }

/* Live counter badge */
.live-badge {
  position: absolute;
  bottom: 48px;
  right: max(20px,5vw);
  background: rgba(9,9,8,.85);
  border: 1px solid rgba(200,168,75,.2);
  border-radius: 14px;
  padding: 14px 20px;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  max-width: 280px;
  opacity: 0;
  animation: fade-up .8s ease 1.2s forwards;
  z-index: 2;
}
.live-badge-top {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 6px;
}
.live-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--red);
  box-shadow: 0 0 8px rgba(217,107,107,.6);
  animation: blink-red 1.4s ease-in-out infinite;
}
@keyframes blink-red { 0%,100%{opacity:1} 50%{opacity:.3} }
.live-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--red);
}
.live-body {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.5;
}
.live-body strong { color: var(--text); font-weight: 500; font-size: 15px; }

/* ═══ TICKER ═══ */
.ticker {
  background: var(--s1);
  border-top: 1px solid rgba(200,168,75,.1);
  border-bottom: 1px solid rgba(200,168,75,.1);
  overflow: hidden;
  padding: 14px 0;
  position: relative;
}
.ticker::before, .ticker::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 80px;
  z-index: 2;
}
.ticker::before { left:0; background:linear-gradient(90deg,var(--s1),transparent); }
.ticker::after  { right:0; background:linear-gradient(-90deg,var(--s1),transparent); }
.ticker-track {
  display: flex;
  white-space: nowrap;
  animation: ticker-scroll 40s linear infinite;
  width: max-content;
}
.ticker-track:hover { animation-play-state: paused; }
.ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 0 32px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--muted);
}
.ticker-item .t-num { color: var(--gold); font-weight: 500; }
.ticker-sep { color: var(--dim); }
@keyframes ticker-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ═══ COST SECTION ═══ */
.cost-section {
  padding: 110px max(20px,5vw);
  text-align: center;
  position: relative;
  overflow: hidden;
  background: var(--black);
}
.cost-grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 56px 56px;
  opacity: .3;
  mask-image: radial-gradient(ellipse 60% 80% at 50% 50%, black, transparent);
  -webkit-mask-image: radial-gradient(ellipse 60% 80% at 50% 50%, black, transparent);
}
.cost-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 24px;
  position: relative;
}
.cost-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(80px,16vw,200px);
  color: var(--gold);
  letter-spacing: -.01em;
  line-height: 1;
  margin-bottom: 20px;
  position: relative;
  text-shadow: 0 0 120px rgba(200,168,75,.15);
}
.cost-desc {
  font-size: clamp(16px,1.8vw,20px);
  color: var(--muted);
  max-width: 560px;
  margin: 0 auto 40px;
  line-height: 1.7;
  font-weight: 300;
  position: relative;
}
.cost-desc strong { color: var(--text); font-weight: 500; }
.cost-cta-hint {
  font-size: 14px;
  color: var(--dim);
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: .08em;
  text-transform: uppercase;
  position: relative;
}

/* Stat row */
.stat-row {
  display: flex;
  justify-content: center;
  gap: 1px;
  background: var(--border);
  border-radius: 18px;
  overflow: hidden;
  max-width: 800px;
  margin: 64px auto 0;
  position: relative;
}
.stat-block {
  flex: 1;
  background: var(--s1);
  padding: 36px 24px;
  text-align: center;
  transition: background .3s;
}
.stat-block:hover { background: var(--s2); }
.stat-block .s-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(44px,5vw,64px);
  color: var(--gold);
  letter-spacing: .01em;
  line-height: 1;
  margin-bottom: 10px;
}
.stat-block .s-txt {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.55;
  font-weight: 300;
}
.stat-block .s-txt strong { color: var(--text); font-weight: 500; }

/* ═══ CALCULATOR ═══ */
.calc-section {
  padding: 100px max(20px,5vw);
  background: var(--s1);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.calc-inner {
  max-width: 1120px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 72px;
  align-items: start;
}
.section-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 22px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.section-tag::before { content:''; width:20px; height:1px; background:var(--gold); }

.calc-h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(44px,5.5vw,68px);
  letter-spacing: .01em;
  line-height: .95;
  margin-bottom: 18px;
}
.calc-h2 .g { color: var(--gold); }
.calc-p {
  font-size: 16px;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 36px;
  font-weight: 300;
}
.calc-p strong { color: var(--text); font-weight: 500; }

/* Sliders */
.slider-wrap { margin-bottom: 24px; }
.slider-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 10px;
}
.s-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
}
.s-val {
  font-size: 16px;
  font-weight: 500;
  color: var(--text);
}
input[type=range] {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 2px;
  background: var(--border2);
  outline: none;
  border-radius: 2px;
  cursor: pointer;
}
input[type=range].amber::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px; height: 20px;
  border-radius: 50%;
  background: var(--gold);
  cursor: pointer; border: none;
  box-shadow: 0 0 0 4px rgba(200,168,75,.12), 0 0 16px rgba(200,168,75,.2);
  transition: box-shadow .15s;
}
input[type=range].amber:active::-webkit-slider-thumb {
  box-shadow: 0 0 0 7px rgba(200,168,75,.15), 0 0 24px rgba(200,168,75,.25);
}
input[type=range].green::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 20px; height: 20px;
  border-radius: 50%;
  background: var(--green);
  cursor: pointer; border: none;
  box-shadow: 0 0 0 4px rgba(126,196,154,.12);
}

/* Result glass card */
.result-glass {
  background: rgba(14,14,13,.7);
  border: 1px solid rgba(200,168,75,.15);
  border-radius: 24px;
  padding: 36px;
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  position: sticky;
  top: 90px;
  box-shadow: 0 0 0 1px rgba(200,168,75,.04), inset 0 1px 0 rgba(255,255,255,.04);
}
.result-glass::before {
  content: '';
  position: absolute;
  top: 0; left: 25%; right: 25%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(200,168,75,.35), transparent);
}

.view-row {
  display: flex;
  gap: 4px;
  background: var(--s3);
  padding: 4px;
  border-radius: 100px;
  border: 1px solid var(--border);
  margin-bottom: 28px;
  width: fit-content;
}
.v-btn {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: .08em;
  text-transform: uppercase;
  padding: 6px 18px;
  border-radius: 100px;
  cursor: pointer;
  border: none;
  background: transparent;
  color: var(--muted);
  transition: all .2s;
}
.v-btn.on {
  background: var(--gold-dim);
  border: 1px solid rgba(200,168,75,.22);
  color: var(--gold);
}

.r-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
}
.r-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(60px,8vw,88px);
  color: var(--gold);
  letter-spacing: .01em;
  line-height: 1;
  margin-bottom: 4px;
  transition: transform .2s ease;
  text-shadow: 0 0 60px rgba(200,168,75,.15);
}
.r-num.pop { transform: scale(1.04); }
.r-per {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 4px;
}
.r-sub { font-size: 13px; color: var(--dim); font-family:'JetBrains Mono',monospace; margin-bottom:8px; }
.r-closing { font-size: 14px; color: var(--red); font-style: italic; min-height: 22px; margin-bottom:22px; line-height:1.4; }

.mini-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 20px;
}
.mini-card {
  background: var(--s3);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px 16px;
}
.mc-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 6px;
}
.mc-val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px;
  color: var(--red);
  letter-spacing: .02em;
  line-height: 1;
}

.rec-block {
  background: var(--s3);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px;
  margin-bottom: 24px;
}
.rec-top {
  font-size: 13px;
  color: var(--muted);
  margin-bottom: 12px;
  line-height: 1.5;
}
.rec-top span { color: var(--text); font-weight: 500; }
.rec-result {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-top: 12px;
}
.rec-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 40px;
  color: var(--green);
  letter-spacing: .02em;
  line-height: 1;
}
.rec-hint { font-size: 12px; color: var(--muted); line-height: 1.4; text-align: right; max-width: 110px; }

/* Demo CTA in calc */
.calc-demo {
  text-align: center;
  padding-top: 24px;
  border-top: 1px solid var(--border);
}
.phone-tap {
  display: inline-block;
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(30px,4vw,46px);
  letter-spacing: .04em;
  color: var(--gold);
  padding: 12px 40px;
  border: 1px solid rgba(200,168,75,.22);
  border-radius: 100px;
  background: var(--gold-dim);
  margin-bottom: 8px;
  transition: all .22s;
  animation: ring-pulse 2.8s ease-out infinite;
}
@keyframes ring-pulse {
  0%{box-shadow:0 0 0 0 rgba(200,168,75,.35);}
  70%{box-shadow:0 0 0 18px rgba(200,168,75,0);}
  100%{box-shadow:0 0 0 0 rgba(200,168,75,0);}
}
