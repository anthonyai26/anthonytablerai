<script>
// ── CURSOR GLOW ──
const glow = document.getElementById('cursor-glow');
document.addEventListener('mousemove', e => {
  glow.style.left = e.clientX + 'px';
  glow.style.top  = e.clientY + 'px';
});

// ── NAV SCROLL ──
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 60);
}, { passive: true });

// ── LIVE COUNTER ──
// Ohio has ~45,000 active agents × 10 calls/week × 40% miss = 18 missed/min statewide
// Columbus metro ~8,000 agents = ~3.2 missed/min
const startTime = Date.now();
let liveCount = 0;
function updateLive() {
  const secs = (Date.now() - startTime) / 1000;
  liveCount = Math.floor(secs / 60 * 3.2);
  const el = document.getElementById('live-count');
  if (el) el.textContent = liveCount.toLocaleString();
}
updateLive();
setInterval(updateLive, 1000);

// ── CALCULATOR ──
let view = 'yr';
function setV(v) {
  view = v;
  document.getElementById('vb-yr').classList.toggle('on', v==='yr');
  document.getElementById('vb-mo').classList.toggle('on', v==='mo');
  calc();
}
function fmt(n) {
  if (n >= 100000) return '$' + Math.round(n/1000) + 'K';
  if (n >= 1000)   return '$' + (Math.round(n/100)/10).toFixed(1) + 'K';
  return '$' + Math.round(n).toLocaleString();
}
function fmtD(n) {
  return n < 0.5 ? '<1' : (Math.round(n*10)/10).toFixed(1);
}
function syncRec(val) {
  document.getElementById('sl-rec').value = val;
  calc();
}
function calc() {
  const price = +document.getElementById('sl-price').value;
  const calls = +document.getElementById('sl-calls').value;
  const miss  = +document.getElementById('sl-miss').value / 100;
  const rec   = +document.getElementById('sl-rec').value / 100;
  document.getElementById('sl-rec2').value = Math.round(rec*100);
  document.getElementById('sv-price').textContent = '$' + price.toLocaleString();
  document.getElementById('sv-calls').textContent = calls + ' call' + (calls===1?'':'s');
  document.getElementById('sv-miss').textContent  = Math.round(miss*100) + '%';
  document.getElementById('sv-rec').textContent   = Math.round(rec*100)  + '%';
  document.getElementById('r-rec-pct').textContent = Math.round(rec*100) + '%';
  const comm   = price * 0.03;
  const annual = calls * 52 * miss * 0.85 * 0.03 * comm;
  const monthly= annual / 12;
  const deals  = calls * 52 * miss * 0.85 * 0.03;
  const missed = Math.round(calls * 52 * miss);
  const recA   = annual * rec;
  const recM   = recA / 12;
  const el = document.getElementById('r-loss');
  const nv = view==='yr' ? fmt(annual) : fmt(monthly);
  if (el.textContent !== nv) { el.classList.add('pop'); el.textContent = nv; setTimeout(()=>el.classList.remove('pop'),200); }
  document.getElementById('r-per').textContent = view==='yr' ? 'per year' : 'per month';
  document.getElementById('r-sub').textContent = view==='yr' ? fmt(monthly)+' every month' : fmt(annual)+' every year';
  document.getElementById('r-closing').textContent = deals>=0.5 ? `That's roughly ${fmtD(deals)} closing${deals>=1.5?'s':''}/yr going to whoever answered first.` : '';
  document.getElementById('r-deals').textContent  = fmtD(deals);
  document.getElementById('r-missed').textContent = missed.toLocaleString();
  document.getElementById('r-rec').textContent    = view==='yr' ? fmt(recA) : fmt(recM);
  document.getElementById('r-rec-hint').textContent = view==='yr' ? fmt(recM)+'/mo' : fmt(recA)+'/yr';
}
calc();

// ── SCROLL REVEAL ──
const rvEls = document.querySelectorAll('.rv');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
}, { threshold: 0.1, rootMargin: '0px 0px -24px 0px' });
rvEls.forEach(el => obs.observe(el));
</script>
